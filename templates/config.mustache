{{!
    Template: tool_tinytoolbar/config

    Renders the visual toolbar configurator admin page.

    Context variables:
        - actionurl:     Form submission URL.
        - sesskey:       Moodle session key.
        - enabled:       Boolean – whether the plugin is currently enabled.
        - active_preset: Currently active preset name.
        - toolbar_json:  Current custom toolbar JSON string.
        - presets:       Array of {name, label, json, active}.
        - previewurl:    URL for the live-preview iframe.
        - str:           Object with pre-fetched language strings.

    @template tool_tinytoolbar/config
    @copyright 2024 IFRN
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}

<div class="tool-tinytoolbar-configurator container-fluid px-0">

    {{! ── Header ─────────────────────────────────────────────────────────── }}
    <div class="d-flex align-items-center mb-4">
        <img src="{{config.wwwroot}}/admin/tool/tinytoolbar/pix/toolbar.svg"
             alt="" width="32" height="32" class="me-2" aria-hidden="true">
        <h2 class="mb-0">{{str.configuretoolbar}}</h2>
    </div>

    {{! ── Config form ─────────────────────────────────────────────────────── }}
    <form id="tinytoolbar-config-form" method="post" action="{{actionurl}}" class="mform">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="action" value="save">

        <div class="row g-4">

            {{! Left column: controls }}
            <div class="col-lg-6">

                {{! Enable toggle }}
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox"
                           id="id_enable_plugin" name="enable_plugin" value="1"
                           {{#enabled}}checked{{/enabled}} role="switch">
                    <label class="form-check-label fw-bold" for="id_enable_plugin">
                        {{str.enable_plugin}}
                    </label>
                </div>

                {{! Preset selector }}
                <div class="mb-3">
                    <label class="form-label fw-bold" for="id_active_preset">
                        {{str.active_preset}}
                    </label>
                    <select id="id_active_preset" name="active_preset" class="form-select">
                        {{#presets}}
                        <option value="{{name}}" {{#active}}selected{{/active}}>{{label}}</option>
                        {{/presets}}
                    </select>
                </div>

                {{! Editor mode toggle button }}
                <div class="mb-3">
                    <button type="button" id="tinytoolbar-toggle-mode" class="btn btn-outline-secondary btn-sm">
                        {{str.visualeditor}}
                    </button>
                </div>

                {{! JSON editor panel }}
                <div id="tinytoolbar-json-panel">
                    <div class="mb-1 d-flex align-items-center justify-content-between">
                        <label class="form-label fw-bold mb-0" for="id_toolbar_json">
                            {{str.toolbar_json}}
                        </label>
                        <span id="tinytoolbar-json-status" aria-live="polite" class="tinytoolbar-json-status"></span>
                    </div>
                    <textarea id="id_toolbar_json" name="toolbar_json"
                              class="form-control font-monospace tinytoolbar-json-textarea"
                              rows="10" spellcheck="false">{{toolbar_json}}</textarea>
                </div>

                {{! Visual drag-and-drop builder panel (hidden by default) }}
                <div id="tinytoolbar-visual-panel" class="d-none">
                    <p class="fw-bold mb-2">{{str.visualeditor}}</p>

                    {{! Available buttons palette }}
                    <div class="mb-3">
                        <p class="small text-muted mb-1">Available buttons (drag to toolbar):</p>
                        <div id="tinytoolbar-available" class="tinytoolbar-palette border rounded p-2 d-flex flex-wrap gap-1">
                            {{#availablebuttons}}
                            <span class="tinytoolbar-btn badge bg-primary" draggable="true" data-button="{{name}}">{{name}}</span>
                            {{/availablebuttons}}
                            <span class="tinytoolbar-btn badge bg-secondary" draggable="true" data-button="|">|</span>
                        </div>
                    </div>

                    {{! Toolbar builder drop zone }}
                    <div class="mb-2">
                        <p class="small text-muted mb-1">Toolbar (drop buttons here):</p>
                        <div id="tinytoolbar-builder"
                             class="tinytoolbar-builder border rounded p-2 d-flex flex-wrap gap-1 min-height-50"
                             aria-label="Toolbar builder drop zone">
                        </div>
                    </div>
                </div>

                {{! Action buttons }}
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" id="tinytoolbar-save" class="btn btn-primary">
                        {{str.savechanges}}
                    </button>
                    <button type="button" id="tinytoolbar-reset" class="btn btn-outline-secondary">
                        {{str.resettodefault}}
                    </button>
                </div>

            </div>

            {{! Right column: live preview }}
            <div class="col-lg-6">
                <p class="fw-bold mb-2">{{str.previewlive}}</p>
                <div class="border rounded overflow-hidden">
                    <iframe id="tinytoolbar-preview-frame"
                            src="{{previewurl}}"
                            title="{{str.previewlive}}"
                            class="w-100"
                            style="height:450px; border:0;"
                            sandbox="allow-scripts allow-same-origin">
                    </iframe>
                </div>
            </div>

        </div>{{! /row }}
    </form>

</div>{{! /container }}
